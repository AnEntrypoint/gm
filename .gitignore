# .gm/prd.yml + .gm/mutables.yml: per-dispatch runtime state, rewritten on
# nearly every PLAN/EXECUTE/VERIFY dispatch -- same class as .gm/witness/
# and gm.db above (transient, regenerated, never durable source). Tracking
# it committed a near-full-file version on every single dispatch (970
# revisions, 743MB logical history for a currently-2.1MB file), roughly
# half of .git on-disk blob weight -- untracked here per this project own
# derived-stores-are-transient-never-tracked policy.
.gm/prd.yml
.gm/mutables.yml
.gm/.gm-continue-count
# <<< plugkit managed
.gm/pw-sock-*/

# agentplug-runner project-local runtime state (kv store, per-project
# plugin-dispatch spool) -- transient, regenerated every session, same
# category as .gm/pw-sock-*/ above
.agentplug/
.agentplug-kv/

# rs-learn/memorize derived binary store -- every live gm session dispatching
# mutable-resolve/prd-add/memorize perpetually grows this file; it is a
# rebuildable derived cache, not source, and had grown past GitHub's 50MB
# recommended limit while tracked (57.18MB, live-witnessed via a real
# git_push warning) -- untracked here, same rule as any other derived store
# per this project's own "derived stores are transient, never tracked" policy.
gm.db
gm.db-wal
gm.db-shm
gm.db-journal

# in-process plugkit probe artifact (transient)
gm-plugkit/.gm/

# tessl tooling marker (foreign, not shipped)
skills/gm-skill/.tessl-plugin/
